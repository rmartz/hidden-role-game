{
  "name": "secret-villain-game",
  "version": "1.0.0",
  "description": "Secret Villain Game - Monorepo",
  "private": true,
  "homepage": "https://github.com/rmartz/secret-villain-game#readme",
  "bugs": {
    "url": "https://github.com/rmartz/secret-villain-game/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rmartz/secret-villain-game.git"
  },
  "license": "ISC",
  "author": "Reed Martz",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter=@secret-villain/app run dev",
    "build": "pnpm --filter=@secret-villain/app run build",
    "test": "pnpm --filter=@secret-villain/app test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,mjs,cjs,ts,tsx,jsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1"
  }
}
