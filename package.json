{
  "name": "secret-villain-game",
  "version": "1.0.0",
  "description": "Secret Villain Game - Monorepo",
  "private": true,
  "homepage": "https://github.com/rmartz/secret-villain-game#readme",
  "bugs": {
    "url": "https://github.com/rmartz/secret-villain-game/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rmartz/secret-villain-game.git"
  },
  "license": "ISC",
  "author": "Reed Martz",
  "type": "module",
  "workspaces": [
    "backend",
    "ui"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "backend:dev": "npm --workspace=@secret-villain/backend run dev",
    "backend:build": "npm --workspace=@secret-villain/backend run build",
    "backend:start": "npm --workspace=@secret-villain/backend start",
    "backend:test": "npm --workspace=@secret-villain/backend test",
    "ui:dev": "npm --workspace=@secret-villain/ui run dev",
    "ui:build": "npm --workspace=@secret-villain/ui run build",
    "ui:preview": "npm --workspace=@secret-villain/ui run preview"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0"
  }
}
