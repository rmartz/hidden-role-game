{
  "name": "@secret-villain/backend",
  "version": "1.0.0",
  "description": "NodeJS server for secret villain game",
  "private": true,
  "homepage": "https://github.com/rmartz/secret-villain-game#readme",
  "bugs": {
    "url": "https://github.com/rmartz/secret-villain-game/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rmartz/secret-villain-game.git"
  },
  "license": "ISC",
  "author": "Reed Martz",
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "postinstall": "tsoa routes",
    "dev": "tsoa routes && node --import tsx src/server/index.ts",
    "start": "node dist/server/index.js",
    "build": "tsoa routes && tsc && tsoa spec",
    "generate:api": "tsoa routes && tsoa spec",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "lint": "eslint ."
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.30.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsoa": "^7.0.0-alpha.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
