{
  "entryFile": "src/server/index.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "controllerPathGlobs": ["src/server/controllers/**/*.ts"],
  "spec": {
    "outputDirectory": "dist",
    "specFileBaseName": "openapi",
    "yaml": true,
    "specVersion": 3,
    "info": {
      "title": "Secret Villain Game API",
      "version": "1.0.0",
      "description": "API for the Secret Villain Game"
    },
    "basePath": "/"
  },
  "routes": {
    "routesDir": "src/server",
    "routesFileName": "routes.ts"
  }
}
