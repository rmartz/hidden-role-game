#!/usr/bin/env sh
# Skip in git worktrees — .git is a file there, not a directory.
# In worktrees, correctness checks run via claude/hooks/pre-commit instead
# (wired by new-worktree.py). PostToolUse hooks handle formatting for agents,
# making lint-staged redundant there.
[ -f ".git" ] && exit 0
pnpm exec lint-staged && pnpm run secrets-check
"$(git rev-parse --show-toplevel)/.github/scripts/check-file-length.sh" --staged
