{
  "rules": {
    "lobbies": {
      ".indexOn": ["public/createdAt"],
      "$lobbyId": {
        "public": {
          ".read": true,
          ".write": false
        },
        "private": {
          ".read": false,
          ".write": false
        }
      }
    },
    "games": {
      ".indexOn": ["public/createdAt"],
      "$gameId": {
        "public": {
          ".read": false,
          ".write": false
        },
        "playerState": {
          "$sessionId": {
            ".read": "auth != null && auth.token.sessionId == $sessionId",
            ".write": false
          }
        },
        "sessionIndex": {
          ".read": false,
          ".write": false
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
