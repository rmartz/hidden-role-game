{
  "name": "@secret-villain/ui",
  "version": "1.0.0",
  "description": "React frontend for secret villain game",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "generate:openapi": "pnpm --filter=@secret-villain/backend run generate:api",
    "generate:client": "pnpm run generate:openapi && openapi --input ../backend/openapi/openapi.yaml --output src/api/generated --client fetch",
    "postinstall": "pnpm run generate:client",
    "lint": "eslint ."
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "openapi-typescript-codegen": "^0.30.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
