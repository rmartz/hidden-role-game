#!/usr/bin/env bash
# Pre-commit guards run before every agent commit in a worktree.
#
# Installed automatically by new-worktree.py when this file is present:
# it sets core.hooksPath=claude/hooks in the git config shared across all
# worktrees, so every worktree created by the script picks up these checks.
# Root-worktree manual commits go through .husky/pre-commit instead.
#
# 1. Conflict markers — block committing leftover Git merge-conflict markers
#                        (also prevents the prettier hook from reflowing and
#                        mangling them in Markdown/YAML)
#
# The file-length hard cap is now the eslint `max-lines` rule, enforced by
# `pnpm lint` (pre-push-verify and CI), so there is no separate length check
# here. (This agent hook does not run lint-staged; the root .husky hook does,
# which additionally surfaces max-lines at commit time for manual commits.)
#
# Bypass: git commit --no-verify
set -e
repo_root="$(git rev-parse --show-toplevel)"
"$repo_root/.github/scripts/check-conflict-markers.sh" --staged
